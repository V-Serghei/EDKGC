<Window x:Class="EDKGC.Views.Windows.CentralWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:EDKGC.ViewModel"
        xmlns:fa5="http://schemas.fontawesome.com/icons/"
        mc:Ignorable="d"
        Title="{Binding Central.Title}"
        Width="1120"
        Height="760"
        MinWidth="980"
        MinHeight="680"
        Icon="../../Resources/cryptography_8948700.png"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource ModernWindowStyle}">

    <Window.DataContext>
        <vm:ViewModelLocator />
    </Window.DataContext>

    <DockPanel Background="{StaticResource WindowGradientBrush}">
        <Menu DockPanel.Dock="Top" Style="{StaticResource ModernMenu}">
            <MenuItem Header="File" Style="{StaticResource ModernMenuItem}">
                <MenuItem Header="Exit"
                          Command="{Binding Central.CloseAppCommand}"
                          Style="{StaticResource ModernMenuItem}" />
            </MenuItem>
            <MenuItem Header="Helper" Style="{StaticResource ModernMenuItem}">
                <MenuItem Header="About Program"
                          Command="{Binding Central.AboutProgramCommand}"
                          Style="{StaticResource ModernMenuItem}" />
            </MenuItem>
            <MenuItem Header="{Binding Central.SelectedItemText}" IsEnabled="False" Style="{StaticResource ModernMenuItem}" />
        </Menu>

        <StatusBar DockPanel.Dock="Bottom" Height="30" Background="#0F172A" Foreground="{StaticResource TextBrush}">
            <StatusBarItem>
                <TextBlock Text="{Binding Central.Status}" />
            </StatusBarItem>
        </StatusBar>

        <TabControl Style="{StaticResource ModernTabControl}" Margin="20">
            <TabItem Style="{StaticResource ModernTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <fa5:ImageAwesome Icon="Solid_Key" Height="15" Margin="0,0,8,0" Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="Symmetric encryption" />
                    </StackPanel>
                </TabItem.Header>

                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="230" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource ModernCard}" Margin="0,0,16,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Algorithms" Style="{StaticResource SectionTitleText}" />
                            <ListView Grid.Row="1"
                                      Margin="0,14,0,0"
                                      Style="{StaticResource ModernListView}"
                                      ItemsSource="{Binding Central.Items}"
                                      SelectedItem="{Binding Central.SelectedItem, Mode=TwoWay}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Padding="8,7" />
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource ModernCard}" Margin="0,0,16,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="112" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Input and key" Style="{StaticResource SectionTitleText}" />
                            <TextBox Grid.Row="1"
                                     Margin="0,12,0,0"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Central.KeyTextAl}"
                                     IsReadOnly="True" />
                            <Button Grid.Row="2"
                                    Content="Generate key"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Left"
                                    Command="{Binding Central.GenKeySymmetricalCommand}" />
                            <TextBox Grid.Row="3"
                                     Margin="0,16,0,0"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Central.TextNonEncrypt, Mode=TwoWay}" />
                            <Button Grid.Row="4"
                                    Content="{Binding Central.ButtonEDecrypt}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    Command="{Binding Central.EncryptTextCommand}" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource ModernCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Result" Style="{StaticResource SectionTitleText}" />
                            <TextBox Grid.Row="1"
                                     Margin="0,12,0,0"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Central.EncryptTextAl, Mode=TwoWay}" />
                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                                <Button Content="Swap"
                                        Style="{StaticResource ModernButton}"
                                        Width="100"
                                        Command="{Binding Central.SwapEncryptDecryptcCommand}" />
                                <Button Content="Copy"
                                        Style="{StaticResource SuccessButton}"
                                        Width="100"
                                        Margin="10,0,0,0"
                                        Click="CopyCentralResult_Click" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Style="{StaticResource ModernTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <fa5:ImageAwesome Icon="Brands_Keycdn" Height="15" Margin="0,0,8,0" Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="Asymmetric encryption" />
                    </StackPanel>
                </TabItem.Header>

                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource ModernCard}" Margin="0,0,16,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="95" />
                                <RowDefinition Height="95" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="{Binding Central.SelectedItemAsumAl, StringFormat={}{0} workspace}" Style="{StaticResource SectionTitleText}" />
                            <ListView Grid.Row="1"
                                      Margin="0,12,0,0"
                                      Height="132"
                                      Style="{StaticResource ModernListView}"
                                      ItemsSource="{Binding Central.ItemsAsymAl}"
                                      SelectedItem="{Binding Central.SelectedItemAsumAl, Mode=TwoWay}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Padding="8,7" />
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <TextBox Grid.Row="2"
                                     Margin="0,12,0,0"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Central.KeyTextAl1}"
                                     IsReadOnly="True" />
                            <TextBox Grid.Row="3"
                                     Margin="0,10,0,0"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Central.KeyTextAl2}"
                                     IsReadOnly="True" />
                            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Content="Generate key"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding Central.GenKeyAsymmetrical2Command}" />
                                <Button Content="{Binding Central.KeyEncState}"
                                        Style="{StaticResource ModernButton}"
                                        Margin="10,0,0,0"
                                        Command="{Binding Central.SwapKeyCommand}" />
                            </StackPanel>
                            <TextBox Grid.Row="5"
                                     Margin="0,16,0,0"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Central.TextNonEncrypt, Mode=TwoWay}" />
                            <Button Grid.Row="6"
                                    Content="{Binding Central.ButtonEDecrypt}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    Command="{Binding Central.EncryptAsymmetricalCommand}" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource ModernCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Result" Style="{StaticResource SectionTitleText}" />
                            <TextBox Grid.Row="1"
                                     Margin="0,12,0,0"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Central.EncryptTextAl, Mode=TwoWay}" />
                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                                <Button Content="Swap"
                                        Style="{StaticResource ModernButton}"
                                        Width="100"
                                        Command="{Binding Central.SwapEncryptDecryptcCommand}" />
                                <Button Content="Copy"
                                        Style="{StaticResource SuccessButton}"
                                        Width="100"
                                        Margin="10,0,0,0"
                                        Click="CopyCentralResult_Click" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Style="{StaticResource ModernTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <fa5:ImageAwesome Icon="Solid_FileSignature" Height="15" Margin="0,0,8,0" Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="Signing" />
                    </StackPanel>
                </TabItem.Header>

                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="390" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource ModernCard}" Margin="0,0,16,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="92" />
                                <RowDefinition Height="92" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Signature input" Style="{StaticResource SectionTitleText}" />
                            <TextBox Grid.Row="1"
                                     Margin="0,12,0,0"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Central.KeyTextAl1}"
                                     IsReadOnly="True" />
                            <TextBox Grid.Row="2"
                                     Margin="0,10,0,0"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Central.KeyTextAl2}"
                                     IsReadOnly="True" />
                            <Button Grid.Row="3"
                                    Content="Generate keys"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Left"
                                    Command="{Binding Central.ButGenKeyPCommand}" />
                            <TextBox Grid.Row="4"
                                     Margin="0,16,0,0"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="{Binding Central.EnterTextS, Mode=TwoWay}" />
                            <Button Grid.Row="5"
                                    Content="Generate signature"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    Command="{Binding Central.GenHashAndEncryptSignatureCommand}" />
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="170" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource ModernCard}" Margin="0,0,8,16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Hash" Style="{StaticResource SectionTitleText}" />
                                <TextBox Grid.Row="1"
                                         Margin="0,12,0,0"
                                         Style="{StaticResource ModernTextBox}"
                                         Text="{Binding Central.HashEntTextS, Mode=TwoWay}" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource ModernCard}" Margin="8,0,0,16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Signature / decrypted hash" Style="{StaticResource SectionTitleText}" />
                                <TextBox Grid.Row="1"
                                         Margin="0,12,0,0"
                                         Style="{StaticResource ModernTextBox}"
                                         Text="{Binding Central.EncryptVerTextBoxS, Mode=TwoWay}" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource ModernCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Verification" Style="{StaticResource SectionTitleText}" />
                                    <TextBlock Text="{Binding Central.TextResp}"
                                               Margin="0,18,0,0"
                                               FontSize="34"
                                               FontWeight="Bold"
                                               Foreground="{Binding Central.TextColor}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <Button Content="Decrypt"
                                            Style="{StaticResource ModernButton}"
                                            Width="130"
                                            Command="{Binding Central.DecryptEncryptHashCommand}" />
                                    <Button Content="Verify"
                                            Style="{StaticResource PrimaryButton}"
                                            Width="130"
                                            Margin="0,10,0,0"
                                            Command="{Binding Central.VerifySignatureCommand}" />
                                    <Button Content="Copy"
                                            Style="{StaticResource SuccessButton}"
                                            Width="130"
                                            Margin="0,10,0,0"
                                            Click="CopySignature_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
