<Window x:Class="EDKGC.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Main.Title}"
        Width="980"
        Height="620"
        MinWidth="900"
        MinHeight="560"
        Icon="../../Resources/EDKGC_ICON.ico"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource ModernWindowStyle}"
        DataContext="{Binding Source={StaticResource Locator}}">

    <Grid Background="{StaticResource WindowGradientBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="36">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="EDKGC"
                           FontSize="52"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}" />
                <TextBlock Text="{Binding Localization.AppSubtitle}"
                           Margin="2,4,0,0"
                           FontSize="17"
                           Foreground="{StaticResource MutedTextBrush}" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,36,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*" />
                    <ColumnDefinition Width="0.85*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource ModernCard}" Padding="28">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding Localization.CryptographyWorkspace}"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}" />
                            <TextBlock Text="{Binding Localization.CentralWorkspaceDescription}"
                                       Margin="0,14,0,0"
                                       Width="520"
                                       HorizontalAlignment="Left"
                                       TextWrapping="Wrap"
                                       FontSize="16"
                                       LineHeight="24"
                                       Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,32,0,0">
                            <Button Content="{Binding Localization.Start}"
                                    Style="{StaticResource PrimaryButton}"
                                    Width="150"
                                    Height="44"
                                    Command="{Binding Main.ShowButtonsCommand}"
                                    CommandParameter="{Binding RelativeSource={RelativeSource Self}}" />
                            <Button Content="{Binding Localization.Exit}"
                                    Style="{StaticResource ModernButton}"
                                    Width="120"
                                    Height="44"
                                    Margin="12,0,0,0"
                                    Command="{Binding Main.ExitCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Column="1"
                              Margin="22,0,0,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding Main.ButtonsPanelVisibility}">
                <StackPanel>
                    <Border Style="{StaticResource ModernCard}" Margin="0,0,0,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding Localization.CentralWorkspace}" Style="{StaticResource SectionTitleText}" />
                            <TextBlock Grid.Row="1"
                                       Text="{Binding Localization.CentralWorkspaceDescription}"
                                       Margin="0,6,0,16"
                                       Style="{StaticResource MutedText}" />
                            <Button Grid.Row="2"
                                    Content="{Binding Localization.Open}"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="Button_Click" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ModernCard}" Margin="0,0,0,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="ISO 27001" Style="{StaticResource SectionTitleText}" />
                            <TextBlock Grid.Row="1"
                                       Text="{Binding Localization.IsoDescription}"
                                       Margin="0,6,0,16"
                                       Style="{StaticResource MutedText}" />
                            <Button Grid.Row="2"
                                    Content="{Binding Localization.Open}"
                                    Style="{StaticResource ModernButton}"
                                    Click="Button_Click_Iso" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ModernCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding Localization.BasicInformation}" Style="{StaticResource SectionTitleText}" />
                            <TextBlock Grid.Row="1"
                                       Text="{Binding Localization.BasicInformationDescription}"
                                       Margin="0,6,0,16"
                                       Style="{StaticResource MutedText}" />
                            <Button Grid.Row="2"
                                    Content="{Binding Localization.Open}"
                                    Style="{StaticResource ModernButton}"
                                    Click="BasicInformation_Click" />
                        </Grid>
                    </Border>
                </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

    </Grid>
</Window>
