<Window x:Class="EDKGC.Views.Windows.IsoResultsWidow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModel="clr-namespace:EDKGC.ViewModel"
        xmlns:wpf1="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        mc:Ignorable="d"
        Title="ISO results"
        Width="980"
        Height="640"
        MinWidth="860"
        MinHeight="560"
        Icon="../../Resources/cryptography_8948700.png"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource ModernWindowStyle}">

    <Window.DataContext>
        <viewModel:ViewModelLocator />
    </Window.DataContext>
    <Grid Background="{StaticResource WindowGradientBrush}" Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource ModernCard}" Margin="0,0,16,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="180" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="{Binding Localization.ThreatLevels}" Style="{StaticResource SectionTitleText}" />
                <ListView Grid.Row="1"
                          Margin="0,12,0,14"
                          Style="{StaticResource ModernListView}"
                          ItemsSource="{Binding IsoViewModelInstance.Items}"
                          SelectedItem="{Binding IsoViewModelInstance.SelectedItemMiniCommand}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Padding="8,7" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <wpf1:PieChart Grid.Row="2"
                               Series="{Binding IsoViewModelInstance.ChartResult}">
                    <wpf1:PieChart.DataTooltip>
                        <wpf1:DefaultTooltip Background="#101827"
                                             Foreground="{StaticResource TextBrush}" />
                    </wpf1:PieChart.DataTooltip>
                </wpf1:PieChart>
                <TextBox Grid.Row="3"
                         Margin="0,14,0,0"
                         Style="{StaticResource ModernTextBox}"
                         Text="{Binding IsoViewModelInstance.ResultPercent}"
                         IsReadOnly="True"
                         TextAlignment="Center" />
            </Grid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource ModernCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding Localization.Recommendations}" Style="{StaticResource SectionTitleText}" />
                <RichTextBox Grid.Row="1"
                             Margin="0,12,0,0"
                             Background="#101827"
                             Foreground="{StaticResource TextBrush}"
                             BorderBrush="{StaticResource BorderBrushSoft}"
                             BorderThickness="1"
                             Padding="12"
                             IsReadOnly="True"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <FlowDocument Foreground="{StaticResource TextBrush}">
                        <Paragraph>
                            <Run Text="{Binding IsoViewModelInstance.TextResult, Mode=OneWay}" />
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </Grid>
        </Border>
    </Grid>
</Window>
