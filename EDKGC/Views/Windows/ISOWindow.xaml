<Window x:Class="EDKGC.Views.Windows.ISOWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa5="http://schemas.fontawesome.com/icons/"
        xmlns:wpf1="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        mc:Ignorable="d"
        Title="ISO 27001"
        Width="1120"
        Height="760"
        MinWidth="980"
        MinHeight="680"
        Icon="../../Resources/cryptography_8948700.png"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource ModernWindowStyle}">

    <DockPanel Background="{StaticResource WindowGradientBrush}">
        <Menu DockPanel.Dock="Top" Style="{StaticResource ModernMenu}">
            <MenuItem Header="File" Style="{StaticResource ModernMenuItem}">
                <MenuItem Header="Exit"
                          Command="{Binding Central.CloseAppCommand}"
                          Style="{StaticResource ModernMenuItem}" />
            </MenuItem>
            <MenuItem Header="Helper" Style="{StaticResource ModernMenuItem}">
                <MenuItem Header="About Program"
                          Command="{Binding Central.AboutProgramCommand}"
                          Style="{StaticResource ModernMenuItem}" />
            </MenuItem>
        </Menu>

        <TabControl Style="{StaticResource ModernTabControl}" Margin="20">
            <TabItem Style="{StaticResource ModernTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <fa5:ImageAwesome Icon="Regular_ChartBar" Height="15" Margin="0,0,8,0" Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="ISO 27001" />
                    </StackPanel>
                </TabItem.Header>

                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="0.9*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource ModernCard}" Margin="0,0,16,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Current question" Style="{StaticResource SectionTitleText}" />
                            <TextBox Grid.Row="1"
                                     Margin="0,14,0,0"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="{Binding IsoViewModelInstance.QuestionCurr, Mode=TwoWay}"
                                     IsReadOnly="True"
                                     TextAlignment="Center" />
                            <UniformGrid Grid.Row="2" Columns="3" Margin="0,16,0,0">
                                <Button Content="Yes"
                                        Style="{StaticResource SuccessButton}"
                                        Margin="0,0,8,0"
                                        Command="{Binding IsoViewModelInstance.RespYesCommand}" />
                                <Button Content="No"
                                        Style="{StaticResource DangerButton}"
                                        Margin="4,0,4,0"
                                        Command="{Binding IsoViewModelInstance.RespNoCommand}" />
                                <Button Content="Do not know"
                                        Style="{StaticResource ModernButton}"
                                        Margin="8,0,0,0"
                                        Command="{Binding IsoViewModelInstance.RespDonTKnowCommand}" />
                            </UniformGrid>
                            <Grid Grid.Row="3" Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Width="96"
                                         Style="{StaticResource ModernTextBox}"
                                         IsReadOnly="True"
                                         TextAlignment="Center"
                                         Text="{Binding IsoViewModelInstance.CurrentIndexQuestion}" />
                                <ProgressBar Grid.Column="1"
                                             Margin="14,0"
                                             VerticalAlignment="Center"
                                             Style="{StaticResource ModernProgressBar}"
                                             Value="{Binding IsoViewModelInstance.Percentage}" />
                                <Button Grid.Column="2"
                                        Width="54"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding IsoViewModelInstance.OpenIsoResultsWindowCommand}">
                                    <fa5:ImageAwesome Icon="Regular_ArrowAltCircleRight" Height="18" Width="18" />
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="260" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource ModernCard}" Margin="0,0,0,16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Threat level" Style="{StaticResource SectionTitleText}" />
                                <wpf1:PieChart Grid.Row="1"
                                               Margin="0,10"
                                               Series="{Binding IsoViewModelInstance.ChartSeries}" />
                                <TextBox Grid.Row="2"
                                         Width="180"
                                         HorizontalAlignment="Center"
                                         Style="{StaticResource ModernTextBox}"
                                         Text="{Binding IsoViewModelInstance.ThreatLevel}"
                                         TextAlignment="Center"
                                         TextChanged="TextBox_TextChanged" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource ModernCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Recommendation" Style="{StaticResource SectionTitleText}" />
                                <TextBox Grid.Row="1"
                                         Margin="0,12,0,0"
                                         Style="{StaticResource ModernTextBox}"
                                         Text="{Binding IsoViewModelInstance.ResponseCurr, Mode=TwoWay}"
                                         IsReadOnly="True" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Style="{StaticResource ModernTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <fa5:ImageAwesome Icon="Solid_InfoCircle" Height="15" Margin="0,0,8,0" Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="Info" />
                    </StackPanel>
                </TabItem.Header>
                <Border Style="{StaticResource ModernCard}" Margin="0,18,0,0">
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding IsoViewModelInstance.TextInfoIso, Mode=OneWay}"
                             IsReadOnly="True" />
                </Border>
            </TabItem>

            <TabItem Style="{StaticResource ModernTabItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <fa5:ImageAwesome Icon="Solid_Table" Height="15" Margin="0,0,8,0" Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="Risk Analysis" />
                    </StackPanel>
                </TabItem.Header>

                <Grid Margin="0,18,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="dataGrid"
                              Style="{StaticResource ModernDataGrid}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="True"
                              SelectionChanged="dataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Threat Event" Binding="{Binding ThreatEvent}" Width="2*" />
                            <DataGridTextColumn Header="SLE" Binding="{Binding SLE, StringFormat={}{0:C}}" Width="*" />
                            <DataGridTextColumn Header="EF" Binding="{Binding EF, StringFormat={}{0:P2}}" Width="*" />
                            <DataGridTemplateColumn Header="Rate of Occurrence" Width="2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBox Text="{Binding RateOfOccurrence.FirstValue, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="50" />
                                            <TextBlock Text=" раз в " VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" />
                                            <TextBox Text="{Binding RateOfOccurrence.SecondValue, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="50" />
                                            <ComboBox SelectedItem="{Binding RateOfOccurrence.Unit, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Width="100">
                                                <ComboBoxItem Content="лет" />
                                                <ComboBoxItem Content="месяцев" />
                                            </ComboBox>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="ARO" Binding="{Binding ARO, StringFormat={}{0:P2}}" IsReadOnly="True" Width="*" />
                            <DataGridTextColumn Header="ALE" Binding="{Binding ALE, StringFormat={}{0:C}}" IsReadOnly="True" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="1"
                            Style="{StaticResource ModernCard}"
                            Padding="12"
                            HorizontalAlignment="Right"
                            Width="340"
                            Margin="0,14,0,0">
                        <TextBox x:Name="TextBoxResult"
                                 Style="{StaticResource ModernTextBox}"
                                 IsReadOnly="True"
                                 TextAlignment="Center"
                                 MinHeight="54" />
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
